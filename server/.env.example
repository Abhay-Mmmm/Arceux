# Environment Variables for Arceux Backend

# Groq API Key (required for AI chatbot and CrewAI agents)
# Get a free key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Groq model to use (llama-3.3-70b-versatile recommended — fast and free tier available)
GROQ_MODEL=llama-3.3-70b-versatile

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
