# Environment Variables for Arceux Backend
# Copy this file to .env and fill in your keys.
# Never commit your actual .env file — it contains secrets.

# ── Groq API Keys ────────────────────────────────────────────────────────────

# Shared fallback key — used by any agent or chatbot that does not have its own
# dedicated key configured below. Required for any AI functionality.
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Per-agent dedicated keys (optional).
# For true rate-limit isolation, each key should come from a separate Groq
# account. Keys from the same account share the same pool — separate accounts
# give each agent its own independent request budget.
# If not set, the agent falls back to GROQ_API_KEY above.
GROQ_API_KEY_ORCHESTRATOR=gsk_...
GROQ_API_KEY_ALERT_HANDLER=gsk_...
GROQ_API_KEY_THREAT_ANALYZER=gsk_...
GROQ_API_KEY_ROOT_CAUSE=gsk_...
GROQ_API_KEY_COMPLIANCE=gsk_...
GROQ_API_KEY_RESPONSE=gsk_...

# Chatbot dedicated key (optional).
# The chatbot uses llama-3.1-8b-instant and runs independently of the agent
# pipeline, so isolating it here prevents chatbot traffic from consuming the
# agents' rate-limit budget.
# Falls back to GROQ_API_KEY if not set.
GROQ_API_KEY_CHAT=gsk_...

# ── Model Selection ──────────────────────────────────────────────────────────

# Model used by all six CrewAI agents. The 70B model provides the depth of
# analysis needed for MITRE ATT&CK mapping, forensic timelines, and compliance
# assessments. Changing this affects analysis quality and token cost.
GROQ_MODEL_AGENTS=llama-3.3-70b-versatile

# Model used by the chatbot. The 8B model is ~4x faster and dramatically
# cheaper, keeping the chatbot responsive while staying within rate limits.
GROQ_MODEL_CHAT=llama-3.1-8b-instant

# ── Detection Thresholds ─────────────────────────────────────────────────────

# River ML anomaly score threshold (0.0–1.0).
# Events with a HalfSpaceTrees score at or above this value emit an
# ANOMALOUS_ACCESS signal. Lower values increase sensitivity (more false
# positives); higher values reduce noise. Default 0.75 is calibrated for the
# synthetic log distribution.
RIVER_ANOMALY_THRESHOLD=0.75

# Minimum number of distinct users an IP must connect to before the lateral
# movement graph pattern fires. Raising this reduces false positives in
# environments with shared NAT or VPN exit IPs.
GRAPH_MIN_USERS=3

# Rolling temporal window for graph edges in seconds.
# Edges (ip→user, user→asset) older than this value are pruned from the
# NetworkX graph on every event. 300 seconds (5 minutes) matches the detection
# rules' sliding windows for consistency.
GRAPH_WINDOW_SECONDS=300

# ── API Config ───────────────────────────────────────────────────────────────

# Uvicorn bind address. 0.0.0.0 accepts connections from all interfaces.
# Change to 127.0.0.1 to restrict to localhost only.
API_HOST=0.0.0.0

# Uvicorn bind port. The frontend dev server proxies to this port.
# Must match VITE_API_URL in client/.env.local if changed.
API_PORT=8000
