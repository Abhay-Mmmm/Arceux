# Environment Variables for Arceux Backend
# Copy this file to .env and fill in your keys.

# ── Shared fallback key ──────────────────────────────────────────────────────
# Used for any agent/chatbot that does not have its own dedicated key below.
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_...

# ── Per-agent dedicated keys (optional, separate rate-limit pools) ───────────
# Each key should come from a separate Groq account for true pool isolation.
# If not set, the agent falls back to GROQ_API_KEY above.
GROQ_API_KEY_ORCHESTRATOR=gsk_...
GROQ_API_KEY_ALERT_HANDLER=gsk_...
GROQ_API_KEY_THREAT_ANALYZER=gsk_...
GROQ_API_KEY_ROOT_CAUSE=gsk_...
GROQ_API_KEY_COMPLIANCE=gsk_...
GROQ_API_KEY_RESPONSE=gsk_...

# ── Chatbot dedicated key ────────────────────────────────────────────────────
# Falls back to GROQ_API_KEY if not set.
GROQ_API_KEY_CHAT=gsk_...

# ── Model selection ──────────────────────────────────────────────────────────
# Agents use the large model for deep analysis.
GROQ_MODEL_AGENTS=llama-3.3-70b-versatile
# Chatbot uses the fast 8B model to stay well under rate limits.
GROQ_MODEL_CHAT=llama-3.1-8b-instant

# ── River ML Anomaly Detection ───────────────────────────────────────────────
# Anomaly score threshold (0.0-1.0)
RIVER_ANOMALY_THRESHOLD=0.75

# ── Server Configuration ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
